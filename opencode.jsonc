{
  "$schema": "https://opencode.ai/config.json",
  "model": "minimax-coding-plan/MiniMax-M2.7",
  "default_agent": "wvhvc-team-leader",
  "instructions": [
    "START-HERE.md",
    "AGENTS.md",
    "README.md",
    "docs/process/*.md",
    "docs/spec/CANONICAL-BRIEF.md",
    "tickets/README.md",
    "tickets/manifest.json",
    "tickets/BOARD.md"
  ],
  "mcp": {
    "browser_research": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@latest"],
      "enabled": false
    },
    "openai_docs": {
      "type": "remote",
      "url": "https://developers.openai.com/mcp",
      "enabled": false
    },
    "blender_agent": {
      "type": "local",
      "command": ["uv", "run", "--project", "/home/rowan/blender-agent/mcp-server", "blender-mcp-server"],
      "enabled": true,
      "timeout": 30000,
      "environment": {
        "BLENDER_MCP_TRANSPORT": "stdio",
        "BLENDER_MCP_BLENDER_EXECUTABLE": "/home/rowan/.local/bin/blender",
        "BLENDER_MCP_TRUST_PROFILE": "unrestricted",
        "BLENDER_MCP_ENABLE_AUDIT_LOGGING": "true"
      }
    }
  },
  "permission": {
    "external_directory": "allow",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "**/*.env": "deny",
      "**/*.env.*": "deny",
      "**/*.env.example": "allow"
    },
    "bash": {
      "*": "deny",
      "pwd": "allow",
      "ls *": "allow",
      "find *": "allow",
      "rg *": "allow",
      "grep *": "allow",
      "sed *": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "python *": "allow",
      "python3 *": "allow",
      "pytest *": "allow",
      "uv *": "allow",
      "ruff *": "allow",
      "npm *": "allow",
      "node *": "allow",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git add *": "allow",
      "git commit *": "allow",
      "mkdir *": "allow",
      "echo *": "allow",
      "touch *": "allow",
      "cp *": "allow",
      "mv *": "allow",
      "godot4 *": "allow",
      "godot *": "allow",
      "java *": "allow",
      "javac *": "allow",
      "cargo *": "allow",
      "rustc *": "allow",
      "go *": "allow",
      "dotnet *": "allow"
    }
  }
}
